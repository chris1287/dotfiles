function aztelematics() {
    az repos list --org https://dev.azure.com/Ivecogrp --project SWALab_HMI_and_Connectivity  --query "[?contains(to_string(@), 'telematics')].name"
}

function git_stats() {
    git ls-files | xargs -n1 git blame --line-porcelain | sed -n 's/^author //p' | sort -f | uniq -ic | sort -nr
}

function git_subs() {
    git submodule foreach 'echo "* $PWD" && git branch && echo "*" ' | grep ^*
}

