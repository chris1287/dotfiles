# .bashrc

# Source global definitions
if [ -f /etc/bashrc ]; then
    . /etc/bashrc
fi

# User specific environment
if ! [[ "$PATH" =~ "$HOME/.local/bin:$HOME/bin:" ]]; then
    PATH="$HOME/.local/bin:$HOME/bin:$PATH"
fi
export PATH

# Uncomment the following line if you don't like systemctl's auto-paging feature:
# export SYSTEMD_PAGER=

# User specific aliases and functions
if [ -d ~/.bashrc.d ]; then
    for rc in ~/.bashrc.d/*; do
        if [ -f "$rc" ]; then
            . "$rc"
        fi
    done
fi
unset rc

export PS1='\[\033[01;32m\]\u@\h\[\033[00m\] \[\033[01;36m\]\w\[\033[00m\] $ '

function azpr() {
    local org="https://dev.azure.com/Ivecogrp"
    local query='.[] 
    | select(.reviewers[]
        | select(.uniqueName=="cristiano.prato2@external.ivecogroup.com" and .vote == 0)
    )
    | [.repository.name, .title, .createdBy.uniqueName] 
    | join("\n") + "\n"'

    for project in SWALab_HMI_and_Connectivity CV_Telematics_MiST CV_PCM3_Applications; do
        echo "Project: $project"
        az repos pr list \
            --organization "$org" \
            --project "$project"  \
            | jq -r "$query"
    done
}

